# ============================================
# Configuración de Jira (Server / Data Center)
# ============================================

# Dominio de tu instancia de Jira (sin https:// ni rutas)
# Ejemplo: jiranext.tuempresa.com
NEXT_PUBLIC_JIRA_DOMAIN=your-jira-domain.com

# Personal Access Token (PAT) generado desde tu perfil de Jira
# (Perfil > Personal Access Tokens). No es el token de id.atlassian.com:
# esta app usa autenticación Bearer, pensada para Jira Server/Data Center.
JIRA_API_TOKEN=your-personal-access-token

# Project Key de tu proyecto en Jira
# Ejemplo: si la URL es https://tu-jira.com/projects/PROJ, usa PROJ
NEXT_PUBLIC_JIRA_PROJECT_KEY=PROJ
